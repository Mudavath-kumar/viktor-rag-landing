# Viktor RAG Frontend — Environment Variables
# Copy this file to .env and fill in your values

# Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe to expose in frontend)
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Backend API URL — change this to your deployed backend URL for production
# For local development: http://localhost:8000/api
# For production (Render.com): https://your-api-name.onrender.com/api
VITE_API_URL=http://localhost:8000/api
